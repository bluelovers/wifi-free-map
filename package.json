{
  "name": "wifi-free-map",
  "version": "1.0.0",
  "description": "免費 WiFi 與充電設施地圖服務",
  "keywords": [
    "wifi",
    "map",
    "free-wifi",
    "charging",
    "leaflet",
    "create-by-yarn-tool"
  ],
  "homepage": "https://github.com/bluelovers/wifi-free-map#readme",
  "bugs": {
    "url": "https://github.com/bluelovers/wifi-free-map/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/bluelovers/wifi-free-map.git"
  },
  "license": "ISC",
  "author": "",
  "sideEffects": false,
  "type": "module",
  "main": "index.js",
  "directories": {
    "doc": "docs",
    "test": "test"
  },
  "files": [
    "AGENTS.md"
  ],
  "scripts": {
    "start": "next start",
    "dev": "next dev --experimental-https",
    "coverage": "yarn run test -- --coverage",
    "lint": "next lint",
    "pretest": "echo pretest",
    "test": "jest -u",
    "test:coverage": "jest --coverage",
    "test:jest": "jest --passWithNoTests",
    "test:jest:clearCache": "jest --clearCache",
    "test:jest:coverage": "node --run test:jest -- --coverage",
    "test:jest:snapshot": "node --run test:jest -- -u",
    "test:snapshot": "yarn run test -- -u",
    "install:frozenLockfile": "yarn-tool install --frozen-lockfile",
    "install:resetLockfile": "yarn-tool install --reset-lockfile",
    "build": "next build",
    "build:data:all": "node --run build:data:convert-raw && node --run build:data:split-grid-wifi && node --run build:data:split-grid-charging && node --run build:data:grid-index",
    "build:data:grid-index": "tsx scripts/build-grid-index.ts",
    "build:data:split-grid-charging": "tsx scripts/split-grid-charging.ts",
    "build:data:split-grid-wifi": "tsx scripts/split-grid-wifi.ts",
    "build:data:convert-raw": "tsx scripts/convert-raw.ts",
    "build:sync:data": "tsx scripts/sync-data.ts",
    "ci:build": "echo ci:build",
    "npm:publish": "npm publish",
    "npm:publish:bump": "node --run version:bump && npm publish",
    "npm:publish:bump:major": "node --run version:bump -- --bump major && npm publish",
    "npm:publish:bump:minor": "node --run version:bump -- --bump minor && npm publish",
    "npm:publish:bump:patch": "node --run version:bump -- --bump patch && npm publish",
    "npm:publish:bump:prerelease": "node --run version:bump -- --bump prerelease && npm publish",
    "pnpm:dedupe": "pnpm dedupe",
    "ws:fix-all": "yarn-tool fix-all --overwriteHostedGitInfo",
    "ws:fix-all:resetStaticFiles": "node --run ws:fix-all -- --resetStaticFiles",
    "preversion": "echo preversion && yarn run test",
    "version": "echo version",
    "version:bump": "yarn-tool version",
    "version:bump:major": "node --run version:bump -- --bump major",
    "version:bump:minor": "node --run version:bump -- --bump minor",
    "version:bump:patch": "node --run version:bump -- --bump patch",
    "version:bump:prerelease": "node --run version:bump -- --bump prerelease",
    "prepare": "echo prepare",
    "prepublishOnly": "yarn run preversion",
    "prepublishOnly:check-bin": "ynpx --quiet @yarn-tool/check-pkg-bin",
    "pack": "echo pack",
    "publish": "echo publish",
    "postpublish": "node --run postpublish:changelog && node --run postpublish:git:commit && node --run postpublish:git:tag && node --run postpublish:git:push",
    "postpublish:changelog": "ynpx --quiet @yarn-tool/changelog && git add ./CHANGELOG.md",
    "postpublish:git:commit": "git commit -m \"chore(release): publish\" . & echo postpublish:git:commit",
    "postpublish:git:push": "git push --follow-tags",
    "postpublish:git:tag": "ynpx --quiet @yarn-tool/tag",
    "postpublishOnly": "echo postpublishOnly",
    "ncu": "yarn-tool ncu -u",
    "ncu:pnpm": "pnpm update",
    "sort-package-json": "yarn-tool sort",
    "tsc:showConfig": "ynpx get-current-tsconfig -p"
  },
  "dependencies": {
    "@ant-design/icons": "^6.1.1",
    "@ant-design/nextjs-registry": "^1.3.0",
    "@jest/globals": "^30.3.0",
    "@react-leaflet/core": "^3.0.0",
    "@types/fs-extra": "^11.0.4",
    "@types/jest": "^30.0.0",
    "@types/leaflet": "^1.9.21",
    "@types/qrcode": "^1.5.6",
    "antd": "^6.3.5",
    "fs-extra": "^11.3.4",
    "idb": "^8.0.3",
    "jest": "^30.3.0",
    "leaflet": "^1.9.4",
    "leaflet-path-drag": "^1.9.5",
    "leaflet-routing-machine": "^3.2.12",
    "next": "^16.2.2",
    "qrcode": "^1.5.4",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-leaflet": "^5.0.0",
    "react-leaflet-cluster": "^4.1.3",
    "swr": "^2.4.1",
    "ts-jest": "^29.4.9",
    "ts-type": "^3.0.13",
    "ts-type-object-entries": "^1.0.10",
    "upath2": "^3.1.23",
    "uuid": "^14.0.0",
    "workbox-window": "^7.4.0",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@bluelovers/jest-config": "^1.1.11",
    "@next/bundle-analyzer": "^16.2.2",
    "@types/node": "^25.5.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@yarn-tool/require-resolve": "^4.0.6",
    "@yarn-tool/ws-find-up-paths": "^1.0.19",
    "sass": "^1.99.0",
    "sort-object-keys2": "^3.0.8",
    "typescript": "^6.0.2"
  }
}
